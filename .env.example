# Copy to .env and fill in. Never commit the real .env.

ENVIRONMENT=development

# Claude API — see https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Postgres + pgvector (matches infra/docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://claimsight:claimsight@localhost:5432/claimsight

# Langfuse (self-host via docker-compose, or use cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Weather API for the fraud cross-check (e.g. OpenWeatherMap, WeatherAPI)
WEATHER_API_KEY=

UPLOAD_DIR=./data/uploads

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
