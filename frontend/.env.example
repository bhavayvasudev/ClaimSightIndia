
# Application backend base URL. The frontend only ever talks to the
# FastAPI backend — it never calls the ai-service directly, so no
# AI_SERVICE_URL belongs here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google sign-in gate in front of the real claim flow (/claims/*). Create
# an OAuth 2.0 Client ID in Google Cloud Console (APIs & Services >
# Credentials) with authorized redirect URI
# http://localhost:3000/api/auth/callback/google for local development.
#
# AUTH_GOOGLE_ID must be the exact same value as the backend's
# AUTH_GOOGLE_CLIENT_ID (backend/.env.example) — the backend checks it
# against every Google ID token's `aud` claim before trusting it.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Random secret used to sign session/JWT cookies. Generate one with:
#   npx auth secret
# (or `openssl rand -base64 33`). Never reuse a production secret in dev.
AUTH_SECRET=
